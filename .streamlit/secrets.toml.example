# Template for Streamlit Community Cloud secrets.
# DO NOT put real keys in a committed file. On Streamlit Cloud, paste these
# into:  App  ->  Settings  ->  Secrets.
# (Locally you can instead keep using your .env file.)

APIFY_TOKEN = "apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENROUTER_API_KEY = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENROUTER_MODEL = "meta-llama/llama-3.3-70b-instruct:free"

# Optional: set this to lock the app behind a password.
# Leave it out / blank to keep the app open.
# APP_PASSWORD = "choose-a-password"
